rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read and write only their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public leaderboard: any signed-in user may read the rankings;
    // each user may only create/update their own entry.
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Weekly leaderboard, bucketed by ISO week. Signed-in users read the
    // rankings; each user may only write their own entry within a week.
    match /leaderboard_weekly/{week}/users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
