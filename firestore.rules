rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // True if the signed-in user has an admins/{uid} document.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Each user can read/write their own profile. Admins (team) can read and
    // write any user document — this powers the in-app admin panel
    // (list sign-ups, toggle premium, grant pedis, suspend accounts).
    match /users/{uid} {
      allow read, write: if request.auth != null
        && (request.auth.uid == uid || isAdmin());

      // User-owned subcollections (e.g. visual-dictionary "finds", consent
      // records). The owner — and admins — may read/write them.
      match /{document=**} {
        allow read, write: if request.auth != null
          && (request.auth.uid == uid || isAdmin());
      }
    }

    // Admin allow-list. A user may read only their own admin doc (so the app
    // can tell whether to show the Admin panel). Membership is granted
    // manually in the Firebase console — clients may never write here.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Public leaderboard: any signed-in user may read the rankings;
    // each user may only create/update their own entry. Admins may also
    // remove entries (e.g. when deleting a user record).
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
    }

    // Weekly leaderboard, bucketed by ISO week. Signed-in users read the
    // rankings; each user may only write their own entry within a week.
    match /leaderboard_weekly/{week}/users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Sankofa Lens corrections: when the on-device labeler misses or
    // mislabels an object, users can type the right word. Write-only from
    // the client (no read/list of others' submissions) — this is a review
    // queue for maintainers, not a public dataset. Only admins may read it
    // to curate/expand the recognized vocabulary; nothing is ever edited or
    // deleted from the client.
    match /lensCorrections/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
