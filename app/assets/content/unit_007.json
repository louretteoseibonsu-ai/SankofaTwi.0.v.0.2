  "unit_title": "Akontaabuo: Tens 40–100",
  "review_required": true,
  "vocabulary_spotlight": {
    "headword": "aduanan",
    "gloss": "The number 40. This unit covers the tens from 40 to 100. Learn these seven words and — with the units 1–9 you already know — you can say any number up to 100.",
    "phonetic_bridge": {
      "pronunciation": "aduanan"
    },
    "example_sentences": [
      "aduanan, aduonum, aduosia — 40, 50, 60.",
      "aduosia nwɔtwe = 68."
    ]
  },
  "grammar_mechanics": {
    "focus": "The tens (40–100) and building any number",
    "explanation": "Each ten has its own word: aduanan 40, aduonum 50, aduosia 60, aduoson 70, aduowɔtwe 80, aduokron 90, ɔha 100. To say a number in between, add the unit (1–9) after the tens word — e.g. 'aduanan enum' = 45, 'aduosia nwɔtwe' = 68. So you don't need to memorise every number; learn the tens and the pattern does the rest.",
    "patterns": [
      "aduanan = 40",
      "aduonum enum = 55",
      "aduokron baako = 91",
      "ɔha = 100"
    ]
  },
