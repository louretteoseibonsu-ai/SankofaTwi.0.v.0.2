  "unit_title": "Abusuafoɔ: Family Members",
  "review_required": true,
  "vocabulary_spotlight": {
    "headword": "ɛna",
    "gloss": "Mother — the centre of the Akan matrilineal household.",
    "phonetic_bridge": {
      "pronunciation": "ɛ-na"
    },
    "example_sentences": [
      "Me na ne m'agya wɔ fie.",
      "Onua baa baako wɔ me."
    ],
    "culture_note": "Chale, family is everything in Akan culture — call any older woman 'ɛna' or 'maame' out of respect, even if she isn't your mother. Recycle Numbers: 'M'abusua mu nnipa edu' = there are ten people in my family."
  },
  "grammar_mechanics": {
    "focus": "Naming members of the abusua (family)",
    "explanation": "Core kinship terms include ɛna (mother), agya (father), ɔba (child), onua (sibling), and nana (grandparent / elder). Gender is added with barima (male) or baa (female), e.g. onua barima (brother).",
    "patterns": [
      "onua + barima → brother",
      "onua + baa → sister",
      "ɛna (mother) · agya (father)"
    ]
  },
