  "review_required": true,
  "vocabulary_spotlight": {
    "headword": "pɛ",
    "gloss": "To want / to like — one of the most useful verbs you'll say every day.",
    "phonetic_bridge": {
      "pronunciation": "pɛ"
    },
    "example_sentences": [
      "Me pɛ nsuo.",
      "Me didi.",
      "Bra ha.",
      "Me nom nsuo."
    ],
    "culture_note": "Chale, a handful of verbs unlock most daily talk. Stack them with what you already know: 'Me pɛ nsuo' = I want water (me + pɛ + nsuo). Add a tense marker and you're flying — 'Me bɛba' = I will come."
  },
  "grammar_mechanics": {
    "focus": "High-frequency everyday verbs",
    "explanation": "These verbs come up constantly. Build sentences as subject + verb (+ object): 'Me pɛ nsuo' = I want water. Then add the tense markers you learned: 're-' for now (Me redidi = I am eating), 'bɛ-' for the future (Me bɛba = I will come), and the n-/m- nasal for negatives (Me mpɛ = I don't want).",
    "patterns": [
      "kɔ (go) · ba (come) · didi (eat) · nom (drink)",
      "pɛ (want) · hunu (see) · te (hear) · ka (say)",
      "Me pɛ nsuo = I want water",
      "Me bɛba = I will come"
    ]
  },
