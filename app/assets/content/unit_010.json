  "grammar_mechanics": {
    "focus": "Counting 61 to 70",
    "explanation": "Tens are built on a base word (edu 10, aduonu 20, aduasa 30, aduanan 40, aduonum 50, aduosia 60, aduoson 70, aduowɔtwe 80, aduokron 90, ɔha 100). From 21 upward a number is the tens word plus the unit, e.g. 'aduonu baako' = 21.",
    "patterns": [
      "aduosia baako = 61",
      "aduosia enum = 65",
      "aduoson = 70"
    ]
  },
