  "review_required": true,
  "vocabulary_spotlight": {
    "headword": "fie",
    "gloss": "Home / house — and how to say 'my', 'your', 'their' home.",
    "phonetic_bridge": {
      "pronunciation": "fi-e"
    },
    "example_sentences": [
      "Me fie.",
      "Wo fie.",
      "Ne fie.",
      "Yɛn fie."
    ],
    "culture_note": "Chale, possessives are easy in Twi — the little word for 'my' or 'your' just sits in front of the thing you own. 'fie' is house, 'me fie' is my house. No endings to change, no stress."
  },
  "grammar_mechanics": {
    "focus": "Possessives — my, your, his/her, our, their",
    "explanation": "A possessive sits BEFORE the noun: me (my), wo (your), ne (his/her/its), yɛn (our), mo (your, plural), wɔn (their). So 'fie' (house) gives me fie (my house), wo fie (your house), ne fie (his/her house). When the noun starts with a vowel, 'me' often shortens with an apostrophe: me + agya → m'agya (my father).",
    "patterns": [
      "me (my) · wo (your) · ne (his/her)",
      "yɛn (our) · mo (your, pl) · wɔn (their)",
      "fie → me fie (my house)",
      "me + agya → m'agya (my father)"
    ]
  },
