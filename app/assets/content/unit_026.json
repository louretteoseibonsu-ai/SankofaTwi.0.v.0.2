  "vocabulary_spotlight": {
    "headword": "Dɛn",
    "gloss": "What? — plus the other question words you need to ask anything.",
    "phonetic_bridge": {
      "pronunciation": "dɛn"
    },
    "example_sentences": [
      "Wo din de sɛn?",
      "Wo firi he?",
      "Hwan ni?",
      "Ɛyɛ sɛn?"
    ],
    "culture_note": "Chale, questions are how you make friends fast in Ghana. Learn the question words and you can ask anyone anything — their name, where they're from, how much something costs. Add 'anaa?' to any sentence to turn it into a yes/no question."
  },
  "grammar_mechanics": {
    "focus": "Asking questions with question words",
    "explanation": "Key Twi question words: Dɛn / Ɛdeɛn (what), Hwan (who), He (where), Da bɛn (when), Adɛn (why), Sɛn (how / how much). They usually sit where the answer would go. For a simple yes/no question, add 'anaa?' (literally 'or?') to the end of a statement: 'Wo kɔ anaa?' = 'Are you going?'",
    "patterns": [
      "Dɛn? (what) · Hwan? (who) · He? (where)",
      "Da bɛn? (when) · Adɛn? (why) · Sɛn? (how)",
      "Yes/no: …anaa?  (Wo kɔ anaa? = Are you going?)",
      "Wo din de sɛn? = What's your name?"
    ]
  },
