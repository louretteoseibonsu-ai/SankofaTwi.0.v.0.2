    "headword": "aduonu baako",
    "gloss": "The number 21. This unit covers 21 through 30.",
    "phonetic_bridge": {
      "pronunciation": "aduonu baako"
    },
    "example_sentences": [
      "aduonu baako, aduonu mmienu, aduonu mmiɛnsa."
    ]
  },
  "grammar_mechanics": {
    "focus": "Counting 21 to 30",
    "explanation": "Tens are built on a base word (edu 10, aduonu 20, aduasa 30, aduanan 40, aduonum 50, aduosia 60, aduoson 70, aduowɔtwe 80, aduokron 90, ɔha 100). From 21 upward a number is the tens word plus the unit, e.g. 'aduonu baako' = 21.",
    "patterns": [
      "aduonu baako = 21",
      "aduonu enum = 25",
      "aduasa = 30"
    ]
  },
