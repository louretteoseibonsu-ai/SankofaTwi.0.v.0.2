rules_version = '2';

// Sankofa Twi — Cloud Storage security rules.
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars live at avatars/{uid}.jpg. Anyone may read them (they're
    // shown on leaderboards); only the signed-in owner may write their own,
    // and only a reasonably-sized image.
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
